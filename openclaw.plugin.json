{
  "id": "smartcron",
  "name": "Smartcron",
  "description": "Gate scheduled OpenClaw runs or execute cron-driven tasks without waking the model.",
  "version": "0.9.1",
  "skills": ["./skills"],
  "homepage": "https://github.com/scottgl9/openclaw-smartcron",
  "repository": "https://github.com/scottgl9/openclaw-smartcron",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rules": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "match": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "trigger": {
                  "type": "string",
                  "enum": ["cron", "heartbeat"]
                },
                "agentId": {
                  "type": "string",
                  "minLength": 1
                },
                "sessionKey": {
                  "type": "string",
                  "minLength": 1
                },
                "channelId": {
                  "type": "string",
                  "minLength": 1
                },
                "runId": {
                  "type": "string",
                  "minLength": 1
                },
                "jobId": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "mode": {
              "type": "string",
              "enum": ["gate", "task"]
            },
            "file": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cwd": {
              "type": "string",
              "minLength": 1
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 300
            },
            "skipExitCodes": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "failOpen": {
              "type": "boolean"
            },
            "logOutput": {
              "type": "boolean"
            }
          },
          "required": ["file"]
        }
      }
    }
  }
}
