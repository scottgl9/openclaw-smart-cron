  "keywords": [
    "openclaw",
    "plugin",
    "cron",
    "heartbeat",
    "scheduler",
    "hook"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
