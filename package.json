{
  "name": "openclaw-plugin-smart-cron",
  "version": "0.1.0",
  "description": "Run agents only when conditions are met, or execute scheduled tasks without waking an agent.",
  "license": "MIT",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.20",
      "minGatewayVersion": "2026.4.20"
    },
    "build": {
      "openclawVersion": "2026.4.20",
      "pluginSdkVersion": "2026.4.20"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
