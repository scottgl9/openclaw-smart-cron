{
  "name": "openclaw-plugin-smart-cron",
  "version": "0.9.1",
  "description": "Gate scheduled OpenClaw runs or execute cron-driven tasks without waking the model.",
  "license": "MIT",
  "author": "Scott Glover <scottgl@gmail.com>",
  "type": "module",
  "homepage": "https://github.com/scottgl9/openclaw-smart-cron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottgl9/openclaw-smart-cron.git"
  },
  "bugs": {
    "url": "https://github.com/scottgl9/openclaw-smart-cron/issues"
  },
  "files": [
    "index.ts",
    "src",
    "dist",
    "types",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.20",
      "minGatewayVersion": "2026.4.20"
    },
    "build": {
      "openclawVersion": "2026.4.20",
      "pluginSdkVersion": "2026.4.20"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "cron",
    "heartbeat",
    "scheduler",
    "hook"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
